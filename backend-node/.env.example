# nhuthungfoto Backend — Environment Reference
# Secrets are managed via `wrangler secret put <KEY>` (prod) or `.dev.vars` (local dev).
# Non-secret vars are set in wrangler.jsonc under "vars".

# --------------------
# wrangler.jsonc vars
# --------------------
# FRONTEND_URL=http://localhost:5173

# --------------------
# Secrets (.dev.vars / wrangler secret)
# --------------------

# Cloudflare R2 S3-compatible API (for pre-signed URLs)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Grading
GEMINI_API_KEY=
OPENAI_API_KEY=

# Payments
SEPAY_API_KEY=
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
