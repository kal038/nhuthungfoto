{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.6",
  "mcp": {
    "cloudflare": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "enabled": true
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "github-mcp": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "docker run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN=$OC_GITHUB_PAT ghcr.io/github/github-mcp-server"
      ],
      "enabled": true
    }
  }
}
